#!groovy
import groovy.json.JsonOutput
import jenkins.model.Jenkins

properties(
        [[$class: 'GithubProjectProperty', projectUrlStr: 'https://git.reform.hmcts.net/case-management/user-profile-app'],
         pipelineTriggers([[$class: 'GitHubPushTrigger']])]
)

def jenkinsLatestBuildStatusJobs = [
    [
        group: 'ccd',
        name: 'ccd-definition-store-api',
        fullName: 'HMCTS_a_to_c/ccd-definition-store-api/master'
    ],
    [
        group: 'ccd',
        name: 'ccd-data-store-api',
        fullName: 'HMCTS_a_to_c/ccd-data-store-api/master'
    ]
]

def collectJenkinsLatestBuildStatuses(List<Map<String, String>> configuredJobs) {
    def rootUrl = Jenkins.instance.getRootUrl()

    if (!rootUrl) {
        error('Jenkins root URL is not configured. Set it in Manage Jenkins > System > Jenkins URL.')
    }

    def builds = configuredJobs.collect { configuredJob ->
        def job = Jenkins.instance.getItemByFullName(configuredJob.fullName as String)

        if (job == null) {
            return [
                group: configuredJob.group,
                name: configuredJob.name,
                result: 'UNKNOWN',
                error: "Jenkins job not found: ${configuredJob.fullName}"
            ]
        }

        def build = job.getLastBuild()

        if (build == null) {
            return [
                group: configuredJob.group,
                name: configuredJob.name,
                result: 'UNKNOWN',
                error: "No builds found for Jenkins job: ${configuredJob.fullName}"
            ]
        }

        return [
            group: configuredJob.group,
            name: configuredJob.name,
            buildNumber: build.getNumber(),
            result: build.getResult()?.toString(),
            timestamp: build.getTimeInMillis(),
            url: rootUrl + build.getUrl()
        ]
    }

    return [
        event_type: 'jenkins_build_statuses',
        client_payload: [
            builds: builds
        ]
    ]
}

pipeline {
    agent any

    options {
        timestamps()
        disableConcurrentBuilds()
    }

    stages {
        stage('Archive latest Jenkins build statuses') {
            steps {
                script {
                    def payload = collectJenkinsLatestBuildStatuses(jenkinsLatestBuildStatusJobs)
                    writeFile file: 'Jenkins-Latest-Builds-Status.json', text: JsonOutput.prettyPrint(JsonOutput.toJson(payload))
                    archiveArtifacts allowEmptyArchive: false, artifacts: 'Jenkins-Latest-Builds-Status.json'
                    currentBuild.description = "Collected ${payload.client_payload.builds.size()} build statuses"
                }
            }
        }
    }
}
