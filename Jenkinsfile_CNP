#!groovy
import groovy.json.JsonOutput
import groovy.json.JsonSlurperClassic

properties(
        [[$class: 'GithubProjectProperty', projectUrlStr: 'https://git.reform.hmcts.net/case-management/user-profile-app'],
         pipelineTriggers([[$class: 'GitHubPushTrigger']])]
)

def jenkinsBaseUrl = 'https://build.hmcts.net'
def jenkinsLatestBuildStatusJobs = [
    [
        group: 'ccd',
        name: 'ccd-definition-store-api',
        fullName: 'HMCTS_a_to_c/ccd-definition-store-api/master'
    ],
    [
        group: 'ccd',
        name: 'ccd-data-store-api',
        fullName: 'HMCTS_a_to_c/ccd-data-store-api/master'
    ]
]

def latestBuildApiUrl(String baseUrl, String fullName) {
    def jobPath = fullName.split('/').collect { "job/${it}" }.join('/')
    return "${baseUrl}/${jobPath}/lastBuild/api/json?tree=number,result,timestamp,url"
}

def collectJenkinsLatestBuildStatuses(String baseUrl, List<Map<String, String>> configuredJobs) {
    def builds = configuredJobs.collect { configuredJob ->
        def apiUrl = latestBuildApiUrl(baseUrl, configuredJob.fullName as String)
        def responseFile = "jenkins-latest-${configuredJob.name}.json"
        def statusFile = "jenkins-latest-${configuredJob.name}.status"

        sh """
            set +e
            curl --globoff --silent --show-error --location --output '${responseFile}' --write-out '%{http_code}' '${apiUrl}' > '${statusFile}'
            exit 0
        """

        def httpStatus = readFile(statusFile).trim()

        if (httpStatus != '200') {
            return [
                group: configuredJob.group,
                name: configuredJob.name,
                result: 'UNKNOWN',
                url: apiUrl,
                error: "Jenkins API returned HTTP ${httpStatus}"
            ]
        }

        def responseText = readFile(responseFile)
        def latestBuild = new JsonSlurperClassic().parseText(responseText)

        return [
            group: configuredJob.group,
            name: configuredJob.name,
            buildNumber: latestBuild.number,
            result: latestBuild.result,
            timestamp: latestBuild.timestamp,
            url: latestBuild.url
        ]
    }

    return [
        event_type: 'jenkins_build_statuses',
        client_payload: [
            builds: builds
        ]
    ]
}

pipeline {
    agent any

    options {
        timestamps()
        disableConcurrentBuilds()
    }

    stages {
        stage('Archive latest Jenkins build statuses') {
            steps {
                script {
                    def payload = collectJenkinsLatestBuildStatuses(jenkinsBaseUrl, jenkinsLatestBuildStatusJobs)
                    writeFile file: 'Jenkins-Latest-Builds-Status.json', text: JsonOutput.prettyPrint(JsonOutput.toJson(payload))
                    archiveArtifacts allowEmptyArchive: false, artifacts: 'Jenkins-Latest-Builds-Status.json'
                    currentBuild.description = "Collected ${payload.client_payload.builds.size()} build statuses"
                }
            }
        }
    }
}
